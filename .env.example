# Seeder wallet — earns sats for serving content
BSV_PRIVATE_KEY=

# Leecher wallet — pays sats to watch (fund with a few thousand sats)
# If set along with BSV_PRIVATE_KEY, enables LIVE mode (real on-chain txs)
BSV_LEECHER_KEY=

# Pitch registration fee receive address (Phase 2 / Task 36).
# Generate with: pnpm tsx scripts/generate-pitch-address.ts
# - PITCH_RECEIVE_ADDRESS is read by run-agent-swarm.ts to start the
#   PitchVerifier. Must match docs/brochure/pitch-config.json.
# - PITCH_RECEIVE_WIF is NOT read by any code. It's stored here so
#   the operator can sweep accumulated pitch fees later from any
#   BSV wallet. Treat it like BSV_PRIVATE_KEY.
# - PITCH_MIN_SATS is optional; defaults to 1000.
PITCH_RECEIVE_ADDRESS=
PITCH_RECEIVE_WIF=
PITCH_MIN_SATS=1000

# Self-hosted Supabase on Hetzner — required for the persistent
# registry, the public productions/leaderboard pages, and the
# PitchVerifier (uses the service role to bypass RLS).
SUPABASE_URL=https://api.b0ase.com
SUPABASE_SERVICE_ROLE_KEY=
